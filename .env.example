# ==============================================================================
# Configurações do Banco de Dados PostgreSQL
# ==============================================================================
# ATENÇÃO: As credenciais do PostgreSQL abaixo e a DATABASE_URL estão interligadas.
# Se você alterar POSTGRES_USER, POSTGRES_PASSWORD ou POSTGRES_DB, certifique-se de 
# atualizar também a string correspondente na DATABASE_URL para manter a sincronia!
POSTGRES_USER=ifal_user
POSTGRES_PASSWORD=ifal_password
POSTGRES_DB=ifal_projetos
# Connection string do backend com o postgres (usando biblioteca asyncpg)
DATABASE_URL=postgresql+asyncpg://ifal_user:ifal_password@db:5432/ifal_projetos

# ==============================================================================
# Configurações do SUAP OAuth2
# ==============================================================================
# Padrões funcionais para testes locais automáticos e offline
SUAP_CLIENT_ID=mock_client_id
SUAP_CLIENT_SECRET=mock_client_secret
SUAP_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ==============================================================================
# Configurações de Segurança e JWT da Aplicação
# ==============================================================================
# ATENÇÃO: NUNCA utilize a chave de exemplo abaixo em produção! 
# Gere uma chave aleatória forte usando: openssl rand -hex 32
JWT_SECRET=mude_isso_em_producao_123456
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=30
